{
  "expo": {
    "name": "kubsu-navigator",
    "slug": "kubsu-navigator",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "kubsunavigator",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.kubsunavigator"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            {
              "fontFamily": "Roboto",
              "fontDefinitions": [
                {
                  "path": "./assets/fonts/Roboto-Regular.ttf",
                  "weight": 400
                },
                {
                  "path": "./assets/fonts/Roboto-Medium.ttf",
                  "weight": 500
                },
                {
                  "path": "./assets/fonts/Roboto-Bold.ttf",
                  "weight": 700
                }
              ]
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}